rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: Deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Portfolio collection: Publicly readable, admin only writable
    // We will assume authentication exists later for writes
    match /portfolio/{item} {
      allow read: if true;
      allow write: if request.auth != null; // Will refine later
    }

    // Analytics / Metrics: Admin only
    match /analytics/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
